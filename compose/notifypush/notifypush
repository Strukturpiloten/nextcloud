ARG PODMAN_NOTIFYPUSH_RUST_IMAGE
ARG PODMAN_NOTIFYPUSH_ALPINE_IMAGE

FROM ${PODMAN_NOTIFYPUSH_RUST_IMAGE} AS build

ARG NOTIFYPUSH_VERSION
ARG NOTIFYPUSH_REPOSITORY

WORKDIR /NOTIFYPUSH

RUN apk update && \
    apk upgrade && \
    apk add --no-cache \
    git

RUN git clone --branch "${NOTIFYPUSH_VERSION}" "${NOTIFYPUSH_REPOSITORY}" .; \
    rustup target add x86_64-unknown-linux-musl; \
    cargo build --release --target=x86_64-unknown-linux-musl

FROM ${PODMAN_NOTIFYPUSH_ALPINE_IMAGE} AS final

COPY --from=build /NOTIFYPUSH/target/x86_64-unknown-linux-musl/release/NOTIFYPUSH /

# Alpine guest user
USER 405

EXPOSE 7867

CMD ["/NOTIFYPUSH", "/config/config.php"]
