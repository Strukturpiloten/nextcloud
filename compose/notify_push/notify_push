ARG PODMAN_NOTIFY_PUSH_RUST_IMAGE
ARG PODMAN_NOTIFY_ALPINE_IMAGE

FROM ${PODMAN_NOTIFY_PUSH_RUST_IMAGE} AS build

ARG NOTIFY_PUSH_VERSION
ARG PODMAN_NOTIFY_PUSH_REPOSITORY

WORKDIR /notify_push

RUN apk update && \
    apk upgrade && \
    apk add --no-cache \
    git

RUN git clone --branch "${NOTIFY_PUSH_VERSION}" "${PODMAN_NOTIFY_PUSH_REPOSITORY}" .; \
    rustup target add x86_64-unknown-linux-musl; \
    cargo build --release --target=x86_64-unknown-linux-musl

FROM ${PODMAN_NOTIFY_ALPINE_IMAGE} AS final

COPY --from=build /notify_push/target/x86_64-unknown-linux-musl/release/notify_push /

# Alpine guest user
USER 405

EXPOSE 7867

CMD ["/notify_push", "/config/config.php"]
